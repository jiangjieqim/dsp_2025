{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "commit all",
            "type": "shell",
            "command":"cd ../cmd & call ci_all.bat",
            "problemMatcher": []
        },
        {
            "label": "commit ${file}",
            "type": "shell",
            "command": "TortoiseGitProc.exe /command:commit /path:${file} /closeonend:0  /logmsg . ",
            "problemMatcher": []
        },
        {
            "label": "chrome ${file}",
            "type": "shell",
            "command":"echo off & cd ../../../ & cd github/jjqmdlib/cmd & call opendoc ${file}",
            // call opendoc ${workspaceFolder}/doc.md
            // "command":"echo ${workspaceFolder}",
            "problemMatcher": []
        },
        {
            "label": "sdcc_compile ${file}",
            "type": "shell",
            // "command":"echo off& cd ../cmd & call compile",
            // D:/github/dsp/libs/utils.c
            // start cmd.exe /k 
            // start cmd.exe /c
            "command":"call sdcc_compile ${workspaceFolder} ${fileBasename}",
            "problemMatcher": []
        },

      
 
  
    
       

    ]
}